      "item": [
        {
          "name": "Tenant Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const payload = pm.response.json();",
                  "  if (payload && payload.data && payload.data.token) {",
                  "    pm.collectionVariables.set('token', payload.data.token);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-Tenant",
                "value": "{{tenant_slug}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"workspace\": \"{{tenant_slug}}\",\n  \"email\": \"demo.owner+{{tenant_slug}}@dressnmore.test\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tenant/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "tenant",
                "login"
              ]
            }
