From a88a2f7e4b3d401146e52050c55902f7de07ce17 Mon Sep 17 00:00:00 2001
From: Cursor Agent <cursor-agent@users.noreply.github.com>
Date: Wed, 17 Jun 2026 14:30:01 +0000
Subject: [PATCH] fix(api): align with Back-DressnMore tenant contract

- Drop withCredentials (Sanctum bearer API; avoids CORS preflight failure).
- Inject X-Tenant header from login endpoints.tenant_slug / tenant.slug.
- Unwrap backend standard envelope { success, message, data, meta } into the
  list ({data,current_page,per_page,total,total_pages}) and single shapes the
  services expect (map meta.last_page -> total_pages).
- auth.types: add tenant + endpoints.tenant_slug.
- clients service: use backend /customers resource path.
---
 src/api/api-contants.ts               | 38 +++++++++++++++++++++++++++
 src/api/api-instance.ts               |  4 ++-
 src/api/v2/auth/auth.types.ts         |  6 +++++
 src/api/v2/clients/clients.service.ts | 12 ++++-----
 4 files changed, 53 insertions(+), 7 deletions(-)

diff --git a/src/api/api-contants.ts b/src/api/api-contants.ts
index 0992664..fad0354 100644
--- a/src/api/api-contants.ts
+++ b/src/api/api-contants.ts
@@ -11,6 +11,13 @@ api.interceptors.request.use((config) => {
     config.headers.Authorization = `Bearer ${token}`;
   }
 
+  // Send the tenant workspace slug so the backend can resolve tenant context
+  // without relying on the request subdomain (required by /api/tenant/*).
+  const tenantSlug = loginData?.endpoints?.tenant_slug ?? loginData?.tenant?.slug;
+  if (tenantSlug) {
+    config.headers["X-Tenant"] = tenantSlug;
+  }
+
   if (config.data instanceof FormData) {
     delete config.headers["Content-Type"];
   }
@@ -26,6 +33,37 @@ api.interceptors.response.use(
         response
       );
     }
+
+    // Normalize the backend's standard envelope { success, message, data, meta }
+    // into the shapes the frontend services expect:
+    //  - lists  -> { data: [...], current_page, per_page, total, total_pages }
+    //  - single -> the inner data object directly
+    const body = response.data;
+    if (
+      body &&
+      typeof body === "object" &&
+      !(body instanceof Blob) &&
+      "success" in body &&
+      "data" in body
+    ) {
+      const inner = (body as Record<string, unknown>).data;
+      const meta = (body as Record<string, unknown>).meta as
+        | Record<string, unknown>
+        | undefined;
+
+      if (Array.isArray(inner)) {
+        response.data = {
+          data: inner,
+          current_page: meta?.current_page,
+          per_page: meta?.per_page,
+          total: meta?.total,
+          total_pages: meta?.total_pages ?? meta?.last_page,
+        };
+      } else {
+        response.data = inner;
+      }
+    }
+
     return response;
   },
   (error) => {
diff --git a/src/api/api-instance.ts b/src/api/api-instance.ts
index e8765f7..29f9528 100644
--- a/src/api/api-instance.ts
+++ b/src/api/api-instance.ts
@@ -35,7 +35,9 @@ export function getDefaultApiBaseUrl(): string {
 
 export const api = axios.create({
   baseURL: getDefaultApiBaseUrl() || undefined,
-  withCredentials: true,
+  // Token-based (Sanctum bearer) API — credentials/cookies are not used.
+  // Keeping this false avoids CORS preflight failures against the tenant API.
+  withCredentials: false,
 });
 
 export function applyTenantApiBaseUrl(url?: string | null) {
